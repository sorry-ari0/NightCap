{
  "name": "nightcap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "client": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:e2e": "playwright test",
    "test:api": "node tests/api-validation.mjs",
    "test:browser": "node tests/browser-audit.mjs",
    "check:clean": "node scripts/check-clean.mjs",
    "release:check": "npm run check:clean && npm run build && npm run test:api && E2E_PORT=3107 npm run test:e2e && npm run test:browser && npm run check:clean"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
